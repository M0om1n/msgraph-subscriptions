extends layout

block content
  div(class='user-flow-shell p-4 p-md-5 mb-4 border rounded-3')
    div(class='d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3')
      h1(class='mb-0') Admin Flow
      span(class='badge bg-dark text-light px-3 py-2') Admin mode

    p(class='lead mb-4') Monitor active subscriptions and inspect calendars by user.

    if subscribedCount > 0
      div(class='alert alert-success')= `Subscribed: ${subscribedCount}`
    if unsubscribedCount > 0
      div(class='alert alert-info')= `Unsubscribed: ${unsubscribedCount}`
    if failedCount > 0
      div(class='alert alert-warning')= `Failed: ${failedCount}`

    div(class='row g-4')
      div(class='col-lg-9')
        div(class='card border-0 shadow-sm h-100')
          div(class='card-body')
            div(class='d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3')
              h2(class='h4 mb-0') Active subscriptions
              span(class='badge bg-secondary')= `${graphSubscriptions ? graphSubscriptions.length : 0} total`

            if graphSubscriptions && graphSubscriptions.length
              div(class='table-responsive')
                table(class='table table-sm table-hover align-middle mb-0')
                  thead(class='table-light')
                    tr
                      th DB
                      th User
                      th Calendar
                      th Events
                      th Fields
                      th Expires
                      th Action
                  tbody
                    each sub in graphSubscriptions
                      tr
                        td
                          if sub.inDb
                            span(class='badge bg-success') ✓
                          else
                            span(class='badge bg-warning text-dark') ✗
                        td(class='small')= sub.userName || '—'
                        td(class='small')= sub.calendarName || '—'
                        td(class='small')= sub.changeType || '—'
                        td
                          if sub.fields && sub.fields.length
                            div(class='d-flex flex-wrap gap-1')
                              each fieldName in sub.fields
                                span(class='badge bg-light text-dark border')= fieldName
                          else
                            span(class='text-muted small') Default event fields
                        td(class='small text-nowrap')= sub.expirationDateTime ? new Date(sub.expirationDateTime).toLocaleString() : '—'
                        td
                          form(method='post' action='/admin-flow/unsubscribe' class='m-0')
                            input(type='hidden' name='subscriptionId' value=sub.id)
                            input(type='hidden' name='userId' value=selectedUserId)
                            button(class='btn btn-sm btn-outline-danger' type='submit') Unsubscribe
            else
              p(class='text-muted mb-0') No active app subscriptions were found.

      div(class='col-lg-3')
        div(class='card border-0 shadow-sm')
          div(class='card-body')
            h2(class='h5') Select user
            form(method='get' action='/admin-flow')
              div(class='mb-3')
                label(class='form-label' for='userId') User
                select(class='form-select' id='userId' name='userId')
                  option(value='') Select a user
                  each user in users
                    option(value=user.id selected=selectedUserId === user.id)= `${user.name}${user.email ? ` (${user.email})` : ''}`
              button(class='btn btn-primary w-100' type='submit') Load calendars

            hr

            h3(class='h6 mb-2') Calendars
            if calendars && calendars.length
              form(method='post' action='/admin-flow/sync-subscriptions')
                input(type='hidden' name='userId' value=selectedUserId)
                div(class='list-group list-group-flush mb-3')
                  each calendar, idx in calendars
                    - const isChecked = selectedCalendarIds && selectedCalendarIds.includes(String(calendar.id).toLowerCase())
                    label(class='list-group-item px-0 py-2 d-flex align-items-start gap-2' for=`admin-calendar-${idx}`)
                      input(class='form-check-input mt-1' type='checkbox' id=`admin-calendar-${idx}` name='calendarIds' value=calendar.id checked=isChecked)
                      span
                        div(class='fw-semibold')= calendar.name
                        if calendar.isDefaultCalendar
                          small(class='text-muted d-block') Default calendar
                button(class='btn btn-primary w-100' type='submit') Subscribe
            else
              p(class='text-muted mb-0 small') Select a user to view calendars.

    div(class='mt-4')
      a(class='btn btn-outline-secondary px-4', href='/') Back to home
