extends layout

block content
  h1 Notifications
  if userMode
    p(class='fs-5 mb-3')= `Notifications should appear below when new calendar events are created for ${user.name}.`
  else
    p(class='fs-5 mb-3')= `Notifications should appear below when new calendar events are created for ${(appOnlyUser && appOnlyUser.name) || (appOnlyUser && appOnlyUser.id) || 'the selected user'}${(appOnlyCalendar && appOnlyCalendar.name) ? ` in calendar ${appOnlyCalendar.name}` : ''}.`
  div(class='d-flex')
    if userMode
      div(class='fs-4 me-2')= user.name
    else
      div(class='fs-4 me-2')= (appOnlyUser && appOnlyUser.name) || (appOnlyUser && appOnlyUser.id) || ''
    button(class='btn btn-outline-secondary me-2'
           type='button'
           data-bs-toggle='collapse'
           data-bs-target='#subscriptionDisplay') Show subscription
    a(class='btn btn-outline-secondary' href=`/${userMode ? 'delegated' : 'apponly'}/signout`) Delete subscription
  div(class='collapse mt-3' id='subscriptionDisplay')
    pre(class='wrapped-pre border bg-light p-2')
      code=subscription ? JSON.stringify(subscription, null, 2) : ''
  hr
  table(class='table')
    thead
      tr
        if userMode
          th Subject
          th Start
        else
          th Organizer
          th Subject
          th Start
    tbody(id='notifications')

  script= `const subscriptionId = '${subscription ? subscription.id : 'none'}';`
  script(src='/javascript/watch-client.js')
